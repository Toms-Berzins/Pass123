{
  "name": "pass123",
  "version": "0.1.0",
  "description": "Privacy-first Chrome (MV3) extension for local, encrypted password storage and generation.",
  "type": "module",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/gen-icons.mjs",
    "zip": "npm run build && cd dist && zip -r ../pass123.zip ."
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@types/chrome": "^0.1.43",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
