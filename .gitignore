# Dependencies
node_modules/

# Build output
dist/
*.zip
*.crx

# Packed-extension private signing key — NEVER commit (signs extension updates)
*.pem

# Vite / TS caches
.vite/
*.tsbuildinfo

# Graphify knowledge graph (generated; rebuild with /graphify)
graphify-out/

# Brainstorming session files (visual companion mockups — local only)
.superpowers/

# Stray vendored viz libs extracted alongside the graph viewer
vis-network@*/
vis-network/

# Local docs (research, business plans, competitor notes — kept out of the repo).
# Ignore docs/ contents by default, but publish the files the public listing links to.
docs/*
!docs/PRIVACY.md
!docs/PERMISSIONS.md
!docs/security-model.svg

# Landing page (kept out of the repo)
landing/

# Local screenshots (dev captures — kept out of the repo)
screenshots/

# Secrets / local env (API keys — NEVER commit)
.env
.env.*
!.env.example

# Playwright test output
test-results/
playwright-report/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Ignore vscode AI rules
.github/instructions/codacy.instructions.md
.graphifyignore
